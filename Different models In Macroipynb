:{"id":"g7e_KBTkSqbm"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# Wealth dynamics"],"metadata":{"id":"zorjiSJdWDJO"}},{"cell_type":"markdown","source":["wealth dynamics - (1+rt)s(wt) + yt\n","\n","Rate of return rt - Depends on some white noise and a autocorrelated process(this can have low effect given, no long run trend of the process)\n","\n","labor income process yt - Similar white noise+ autocorrelated process"],"metadata":{"id":"A_cOsIjhW4iy"}},{"cell_type":"code","source":["wealth_dynamics_data = [\n","    ('w_hat',  float64),    # savings parameter\n","    ('s_0',    float64),    # savings parameter\n","    ('c_y',    float64),    # labor income parameter\n","    ('mu_y',    float64),    # labor income paraemter\n","    ('sig_y',    float64),    # labor income parameter\n","    ('c_r',    float64),    # rate of return parameter\n","    ('mu_r',    float64),    # rate of return parameter\n","    ('sig_r',    float64),    # rate of return parameter\n","    ('a',      float64),    # aggregate shock parameter\n","    ('b',      float64),    # aggregate shock parameter\n","    ('sig_z',    float64),    # aggregate shock parameter\n","    ('z_mean', float64),    # mean of z process\n","    ('z_var', float64),     # variance of z process\n","    ('y_mean', float64),    # mean of y process\n","    ('R_mean', float64)     # mean of R process\n","]"],"metadata":{"id":"tzGTr3fFXgyn"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["@jitclass(wealth_dynamics_data)\n","\n","class wealth_dynamics:\n","\n","  def __init__(self, w_hat=1.0,\n","                 s_0=0.75,\n","                 c_y=1.0,\n","                 mu_y=1.0,\n","                 sig_y=0.2,\n","                 c_r=0.05,\n","                 mu_r=0.1,\n","                 sig_r=0.5,\n","                 a=0.5,\n","                 b=0.0,\n","                 sig_z=0.1):\n","\n","    ## parameters of the process\n","    self.w_hat = w_hat\n","    self.s_0 = s_0\n","    self.c_y = c_y\n","    self.mu_y = mu_y\n","    self.sig_y = sig_y\n","    self.c_r = c_r\n","    self.mu_r = mu_r\n","    self.sig_r = sig_r\n","    self.a = a\n","    self.b = b\n","    self.sig_z = sig_z\n","\n","    ## moments from the parameters of the process (Z, R, y)\n","    self.z_mean = b/(1-a)\n","    self.z_var = sig_z**2/(1-a**2)\n","    self.y_mean = c_y*np.exp(self.z_mean + self.z_var / 2) + np.exp(mu_y + sig_y**2 / 2)\n","    self.R_mean = c_r * np.exp(self.z_mean + self.z_var / 2) + np.exp(mu_r + sig_r**2 / 2)\n","\n","     # Test a stability condition that ensures wealth does not diverge\n","        # to infinity.\n","    α = self.R_mean * self.s_0\n","    if α >= 1:\n","        raise ValueError(\"Stability condition failed.\")\n","\n","  def parameters(self):\n","    return (self.w_hat, self.s_0, self.c_y, self.mu_y, self.sig_y, self.c_r, self.mu_r, self.sig_r, self.a, self.b, self.sig_z)\n","\n","  def update_states(self, w, z):\n","\n","    params = self.parameters()\n","    w_hat, s_0, c_y, mu_y, sig_y, c_r, mu_r, sig_r, a, b, sig_z = params\n","\n","    zt = a*z + b + sig_z*np.random.randn()\n","    yt = c_y*np.exp(zt) + np.exp(mu_y + sig_y*np.random.randn())\n","    wt = yt\n","\n","    if w>w_hat:\n","      rt = c_r*np.exp(zt) + np.exp(mu_r + sig_r*np.random.randn())\n","      wt += rt*s_0*w\n","    else:\n","      wt = 0\n","\n","    return wt, zt, yt\n","\n"],"metadata":{"id":"CO3dLRphZg9k"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["@jit\n","def wealth_time_series(wdy, w_0, n):\n","    \"\"\"\n","    Generate a single time series of length n for wealth given\n","    initial value w_0.\n","\n","    The initial persistent state z_0 for each household is drawn from\n","    the stationary distribution of the AR(1) process.\n","\n","        * wdy: an instance of WealthDynamics\n","        * w_0: scalar\n","        * n: int\n","\n","\n","    \"\"\"\n","    z_0 = wdy.z_mean + np.sqrt(wdy.z_var) * np.random.randn()\n","    w = np.empty(n)\n","    zt = np.empty(n)\n","    yt = np.empty(n)\n","\n","    w[0] = w_0\n","    zt[0] = z_0\n","\n","    for t in range(n-1):\n","        # Unpack all three returned values from update_states\n","        # Assign values to the pre-allocated NumPy arrays\n","        w[t+1], zt[t+1], yt[t+1] = wdy.update_states(w[t], zt[t])\n","\n","    # Return all three time series\n","    return w, zt, yt"],"metadata":{"id":"sWCz0ETFXood"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["wdy = wealth_dynamics()\n","ts_length = 200\n","wt,zt,yt = wealth_time_series(wdy, wdy.y_mean, ts_length)"],"metadata":{"id":"m4zG_YtOmPzG"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["fig, ax = plt.subplots(1,3, figsize=(12,4))\n","ax[0].plot(wt)\n","ax[0].set_xlabel('Time')\n","ax[0].set_ylabel('Wealth')\n","\n","ax[1].plot(yt)\n","ax[1].set_xlabel('Time')\n","ax[1].set_ylabel('Income')\n","\n","ax[2].plot(zt)\n","ax[2].set_xlabel('Time')\n","ax[2].set_ylabel('Persistent State')\n","\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":388},"id":"WVtk1rHyrpXA","executionInfo":{"status":"ok","timestamp":1762810918821,"user_tz":300,"elapsed":1247,"user":{"displayName":"Kaustav Sen","userId":"12542047162511783465"}},"outputId":"e32daa33-482d-44ec-e72c-3bc88242c541"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x400 with 3 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["# Consumption Smoothing"],"metadata":{"id":"wdSL3BEmSD-l"}},{"cell_type":"code","source":[],"metadata":{"id":"3Qaj8Yj2SpdL"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"YKRRFZx2Spfe"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"9xvFTye1Spi2"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["# Hall's Model (Consumption)"],"metadata":{